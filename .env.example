# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****
DATABASE_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# --- Firebase settings ---
# The content of your Firebase Service Account JSON file (stringified)
FIREBASE_SERVICE_ACCOUNT=****

# --- Zalo Mini App / Bot settings ---
ZALO_ACCESS_TOKEN=****
# A custom secret key to secure your Zalo Webhook (should match x-bot-api-secret-token)
ZALO_SECRET_KEY=****

# --- Supabase settings ---
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=****
NEXT_PUBLIC_SUPABASE_ANON_KEY=****
SUPABASE_SERVICE_ROLE_KEY=****
